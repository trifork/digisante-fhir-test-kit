# Copy to .env and adjust. Used by build.sh and docker-compose.yml.

# --- Image versioning ---------------------------------------------------------
# HAPI FHIR base image version (a hapiproject/hapi tag). Baked into the image NAME.
HAPI_VERSION=v8.4.0-3
# The test kit's own release version. Carried as a separate image TAG.
IMAGE_VERSION=0.1.0

# --- Implementation Guides to load at startup --------------------------------
# Comma-separated list. Each item is either a package .tgz URL, or explicit
# coordinates as name@version=url. Loaded into the server on boot.
#   IG_URLS=hl7.fhir.us.core@6.1.0=https://packages.simplifier.net/hl7.fhir.us.core/6.1.0
# Multiple:
#   IG_URLS=https://example.org/igA/package.tgz,my.ig@1.0.0=https://example.org/igB/package.tgz
IG_URLS=

# Each loaded IG's declared dependency packages are fetched and installed too
# (transitively), so base IGs and profiles referenced via the
# structuredefinition-imposeProfile extension are available. A few HL7
# "infrastructure" packages cannot be ingested by HAPI's installer and would
# abort startup, so they are excluded by default. Override (comma-separated
# regexes on package id); set empty to attempt installing everything.
# IG_DEPENDENCY_EXCLUDES=hl7.terminology.r4,hl7.fhir.uv.xver-r5.r4

# --- Postgres ----------------------------------------------------------------
POSTGRES_DB=hapi
POSTGRES_USER=hapi
POSTGRES_PASSWORD=hapi

# --- Ports -------------------------------------------------------------------
# Generic hapi.fhir.org-style tester + FHIR REST API.
FHIR_PORT=8080
